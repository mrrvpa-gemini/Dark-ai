<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DarkLordAI" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="android:statusBarColor">@color/darker_bg</item>
        <item name="android:navigationBarColor">@color/darker_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">@color/dark_red</item>
        <item name="colorPrimaryVariant">@color/blood_red</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimationTransition</item>
    </style>

    <style name="Theme.DarkLordAI.Splash" parent="Theme.DarkLordAI">
        <item name="android:windowBackground">@drawable/splash_gradient</item>
    </style>

    <style name="WindowAnimationTransition" parent="@android:style/Animation.Activity">
        <item name="android:windowEnterAnimation">@anim/fade_in</item>
        <item name="android:windowExitAnimation">@anim/fade_out</item>
    </style>
</resources>
